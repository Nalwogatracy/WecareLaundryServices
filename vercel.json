{
    "version": 2,
    
    "routes": [
        {
            "src": "/",
            "dest": "/index.html"
        },
        {
            "src": "/booking",
            "dest": "/booking.html"
        },
        {
            "src": "/contact",
            "dest": "/contact.html"
        },
        {
            "src": "/track-order",
            "dest": "/track-order.html"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}
